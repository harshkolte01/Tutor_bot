# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&channel_binding=require

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-in-production

# JWT
JWT_SECRET_KEY=change-jwt-secret-in-production!!

# Embeddings via wrapper
WRAPPER_BASE_URL=
WRAPPER_KEY=
WRAPPER_EMBEDDING_MODEL=gemini/gemini-embedding-001
WRAPPER_TIMEOUT=120

# Ollama generation
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=qwen3.5:0.8b
OLLAMA_FALLBACK_MODEL=
OLLAMA_REASONING_EFFORT=none
OLLAMA_TIMEOUT=120
OLLAMA_MAX_RETRIES=1
OLLAMA_BASE_DELAY=0.5

# Frontend -> Backend
API_BASE_URL=http://localhost:5000

# Allowed browser origins for API CORS (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000,http://127.0.0.1:3000
